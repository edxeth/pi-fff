{
  "name": "pi-fff",
  "version": "0.2.5",
  "description": "pi extension: FFF-powered fuzzy file and content search",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SamuelLHuber/pi-fff.git"
  },
  "homepage": "https://github.com/SamuelLHuber/pi-fff#readme",
  "bugs": {
    "url": "https://github.com/SamuelLHuber/pi-fff/issues"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "fff",
    "search",
    "grep",
    "fuzzy-search",
    "ai-agent"
  ],
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ff-labs/fff-bun": "^0.6.1",
    "@ff-labs/fff-node": "^0.6.0"
  },
  "overrides": {
    "@ff-labs/fff-bin-darwin-arm64": "0.6.1",
    "@ff-labs/fff-bin-darwin-x64": "0.6.1",
    "@ff-labs/fff-bin-linux-x64-gnu": "0.6.1",
    "@ff-labs/fff-bin-linux-arm64-gnu": "0.6.1",
    "@ff-labs/fff-bin-linux-x64-musl": "0.6.1",
    "@ff-labs/fff-bin-linux-arm64-musl": "0.6.1",
    "@ff-labs/fff-bin-win32-x64": "0.6.1",
    "@ff-labs/fff-bin-win32-arm64": "0.6.1"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "@types/bun": "^1.3.12",
    "@types/node": "^24.5.2",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": [
    "koffi",
    "protobufjs"
  ]
}
